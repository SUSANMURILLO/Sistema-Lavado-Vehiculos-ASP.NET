@model _03075.Proyecto_1.SusanMurillo.Models.Lavado

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Lavado</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Placa -->
            <div class="form-group">
                <label asp-for="PlacaVehiculo" class="control-label"></label>
                <select asp-for="PlacaVehiculo" class="form-control" id="PlacaVehiculoSelect" asp-items="ViewBag.PlacasVehiculos">
                    <option value="">Seleccione una placa</option>
                </select>
                <span asp-validation-for="PlacaVehiculo" class="text-danger"></span>
            </div>

            <!-- Cliente -->
            <div class="form-group">
                <label asp-for="IdCliente" class="control-label"></label>
                <input asp-for="IdCliente" class="form-control" id="ClienteIdInput" readonly />
                <input type="hidden" asp-for="IdCliente" />
                <span asp-validation-for="IdCliente" class="text-danger"></span>
            </div>

            <!-- Empleado -->
            <div class="form-group">
                <label>Empleado</label>
                <select asp-items="ViewBag.Empleados" class="form-control" name="CedulaEmpleado"></select>
            </div>

            <!-- Tipo de lavado -->
            <div class="form-group">
                <label asp-for="TiposDeLavado" class="control-label"></label>
                <select asp-for="TiposDeLavado" asp-items="ViewBag.TiposLavado" class="form-control" id="tipodelavado">
                    <option value="">Seleccione un tipo</option>
                </select>
                <span asp-validation-for="TiposDeLavado" class="text-danger"></span>
            </div>

            <!-- Monto fijo -->
            <div class="form-group" id="montoFijoGroup">
                <label>Monto:</label>
                <input type="text" id="montoFijo" class="form-control" readonly />
            </div>

            <!-- Monto personalizado -->
            <div class="form-group" id="montoPersonalizadoGroup" style="display:none;">
                <label>Ingrese monto personalizado para "La joya":</label>
                <input type="number" step="0.01" class="form-control" id="montoPersonalizado" />
            </div>

            <!-- Pago e Impuesto -->
            <input type="hidden" asp-for="pago" id="pago" />

            <div class="form-group">
                <label>Impuesto</label>
                <input type="text" id="impuestoVisible" class="form-control" readonly />
                <input type="hidden" asp-for="Impuesto" id="Impuesto" />
            </div>

            

            <!-- Estado -->
            <div class="form-group">
                <label asp-for="Estado" class="control-label"></label>
                <select asp-for="Estado" asp-items="ViewBag.EstadosLavado" class="form-control"></select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <!-- Botón -->
            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const precios = {
                "Básico": 5000,
                "Premium": 8000,
                "Deluxe": 12000,
                "La joya": null
            };

            const selectTipo = document.getElementById("tipodelavado");
            const montoFijo = document.getElementById("montoFijo");
            const montoPers = document.getElementById("montoPersonalizado");
            const montoFijoGroup = document.getElementById("montoFijoGroup");
            const montoPersGroup = document.getElementById("montoPersonalizadoGroup");
            const campoPago = document.getElementById("pago");
            const impuestoVisible = document.getElementById("impuestoVisible");
            const impuestoOculto = document.getElementById("Impuesto");

            const actualizarMonto = () => {
                const tipo = selectTipo.value;

                let monto = 0;

                if (!tipo || !(tipo in precios)) {
                    montoFijoGroup.style.display = "none";
                    montoPersGroup.style.display = "none";
                    montoFijo.value = "";
                    campoPago.value = "";
                    impuestoVisible.value = "";
                    impuestoOculto.value = "";
                    return;
                }

                if (tipo === "La joya") {
                    montoFijoGroup.style.display = "none";
                    montoPersGroup.style.display = "block";
                    monto = parseFloat(montoPers.value) || 0;
                } else {
                    montoFijoGroup.style.display = "block";
                    montoPersGroup.style.display = "none";
                    monto = precios[tipo];
                    montoFijo.value = monto;
                }

                campoPago.value = monto;
                const impuesto = (monto * 0.13).toFixed(2);
                impuestoVisible.value = impuesto;
                impuestoOculto.value = impuesto;
            };

            // Eventos de cambio
            selectTipo.addEventListener("change", actualizarMonto);
            montoPers.addEventListener("input", actualizarMonto);

            // Relación placa -> cliente
            const placasYClientes = @Html.Raw(ViewBag.PlacasYClientesJson);
            const placaSelect = document.getElementById("PlacaVehiculoSelect");
            const inputVisible = document.getElementById("ClienteIdInput");
            const inputOculto = document.querySelector('input[name="IdCliente"]');

            if (placaSelect) {
                placaSelect.addEventListener("change", function () {
                    const placaSeleccionada = this.value;
                    const cliente = placasYClientes.find(p => p.Placa === placaSeleccionada);

                    inputVisible.value = cliente ? cliente.ClienteId : "";
                    inputOculto.value = cliente ? cliente.ClienteId : "";
                });
            }

            // Forzar actualización al cargar
            actualizarMonto();
            selectTipo.dispatchEvent(new Event("change"));

            // Recalcular antes de enviar
            const form = document.querySelector("form");
            if (form) {
                form.addEventListener("submit", function () {
                    actualizarMonto();
                   console.log("Impuesto final:", impuestoOculto.value); // para debug
                });
            }
        });
    </script>
}